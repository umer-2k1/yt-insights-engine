generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id                String     @id @default(cuid())
  youtubeChannelId  String?    @unique
  title             String
  url               String     @unique
  nicheLabel        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  videos            Video[]
  analyses          Analysis[]
  nicheComparisons  NicheComparison[]
}

model Video {
  id               String         @id @default(cuid())
  channelId        String
  youtubeVideoId   String?        @unique
  title            String
  description      String
  publishedAt      DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  channel          Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  metricSnapshots  VideoMetric[]
  comments         Comment[]
  transcript       Transcript?
}

model VideoMetric {
  id             String   @id @default(cuid())
  videoId        String
  viewCount      Int
  likeCount      Int
  commentCount   Int
  velocityScore  Float
  fetchedAt      DateTime @default(now())
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comment {
  id                String    @id @default(cuid())
  videoId           String
  youtubeCommentId  String?
  text              String
  intentLabel       String?
  likeCount         Int       @default(0)
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  video             Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Transcript {
  id               String   @id @default(cuid())
  videoId          String   @unique
  source           String
  language         String
  transcriptText   String
  isAutoGenerated  Boolean  @default(true)
  fetchedAt        DateTime @default(now())
  video            Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Analysis {
  id             String   @id @default(cuid())
  channelId      String
  status         String
  inputConfig    Json
  resultJson     Json?
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model NicheCreator {
  id               String            @id @default(cuid())
  nicheLabel       String
  youtubeChannelId String            @unique
  channelTitle     String
  score            Float
  snapshotAt       DateTime          @default(now())
  comparisons      NicheComparison[]
}

model NicheComparison {
  id                String       @id @default(cuid())
  channelId         String
  nicheCreatorId    String
  topicCoverage     Float
  formatMix         Float
  titlePattern      Float
  thumbnailStyle    Float
  postingCadence    Float
  engagementRate    Float
  createdAt         DateTime     @default(now())
  channel           Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  nicheCreator      NicheCreator @relation(fields: [nicheCreatorId], references: [id], onDelete: Cascade)
}
