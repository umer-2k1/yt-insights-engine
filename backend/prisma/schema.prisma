generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id               String     @id @default(cuid())
  youtubeChannelId String?    @unique
  title            String
  url              String     @unique
  nicheLabel       String?
  // Provenance of the most recent ingestion: "youtube" | "demo".
  dataSource       String     @default("demo")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  videos           Video[]
  analyses         Analysis[]
}

model Video {
  id              String        @id @default(cuid())
  channelId       String
  youtubeVideoId  String
  title           String
  description     String
  publishedAt     DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  channel         Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  metricSnapshots VideoMetric[]
  comments        Comment[]
  transcript      Transcript?

  // A YouTube video id is only meaningful within its channel; global uniqueness
  // breaks demo-mode ingestion of multiple channels.
  @@unique([channelId, youtubeVideoId])
}

model VideoMetric {
  id            String   @id @default(cuid())
  videoId       String
  viewCount     Int
  likeCount     Int
  commentCount  Int
  velocityScore Float
  fetchedAt     DateTime @default(now())
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comment {
  id               String    @id @default(cuid())
  videoId          String
  youtubeCommentId String?
  text             String
  intentLabel      String?
  likeCount        Int       @default(0)
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  video            Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Transcript {
  id              String   @id @default(cuid())
  videoId         String   @unique
  source          String
  language        String
  transcriptText  String
  isAutoGenerated Boolean  @default(true)
  fetchedAt       DateTime @default(now())
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Analysis {
  id          String    @id @default(cuid())
  channelId   String
  status      String
  // Provenance of the snapshot this analysis was computed from: "youtube" | "demo".
  dataSource  String    @default("demo")
  inputConfig Json
  resultJson  Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}
