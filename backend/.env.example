# --- Server ---
# Port the API listens on.
PORT=4000
# Origin allowed by CORS (the frontend dev server).
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage (both optional) ---
# Redis backs the job store, cache, and queue. Leave unset to run fully in-memory
# (single process only). Matches `docker compose up` at the repo root.
REDIS_URL="redis://localhost:6379"
# PostgreSQL persists channels, videos, comments, and analyses. Leave unset to skip
# persistence entirely. Matches `docker compose up` at the repo root.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/yt_insights?schema=public"

# --- YouTube Data API v3 (optional) ---
# With a key: real channel ingestion. Without a key: the app runs in DEMO MODE and
# every analysis is generated from labeled sample data (dataSource: "demo").
YOUTUBE_API_KEY=""

# --- LLM recommendation layer (optional, OpenAI-compatible endpoint) ---
# With a key: content gaps and suggested videos are LLM-generated (recommendationSource:
# "llm"). Without a key: rule-based heuristics are used and labeled accordingly.
LLM_API_KEY=""
LLM_API_BASE_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.1-8b-instant"
LLM_TEMPERATURE=0.2

# --- Worker tuning ---
# Maximum time a single analysis job may run before being marked failed.
JOB_TIMEOUT_MS=180000
